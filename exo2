  DEBUT
    AFFICHER "Entrer les 2 réels à multiplier"
    AFFICHER "a = "
    LIRE (a)
    AFFICHER "b = "
    LIRE (b)
    SI (a==0) ou (b==0) ALORS
      AFFICHER "Le produit est nul"
    SINON
      SI ((a<0) et (b<0)) ou ((a>0) et (b>0)) ALORS
        AFFICHER "Le produit est positif"
