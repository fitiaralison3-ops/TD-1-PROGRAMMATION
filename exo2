  printf ("b = ");
  scanf ("%f",&b);
  if ((a==0 || b==0))
    {
      printf ("Le produit est nul");
    }
  else
    {
      if ((a<0 && b<0) || (a>0 && b>0))
        {
          printf ("Le produit est positif");
        }
      else if ((a<0 && b>0) || (a>0 && b<0)) 
        {
